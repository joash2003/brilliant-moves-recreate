# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Upstream lc0 is excluded from this repo (see patches/ and README).
# Clone vanilla lc0 at the pinned SHA and apply the patch; do not track the
# source or build tree here.
lc0-upstream/

# Any lc0 build artefacts that may show up inside the authors' folder
brilliant-moves-clf/brilliant_moves_clf/lc0/build/
brilliant-moves-clf/brilliant_moves_clf/lc0/subprojects/*/
!brilliant-moves-clf/brilliant_moves_clf/lc0/subprojects/*.wrap

# Submission artefact (generated by make_submission.ps1)
submission.zip

# Training run artefacts (keep scaler.pkl + pretrained model only)
brilliant-moves-clf/brilliant_moves_clf/models/model_*.pth
brilliant-moves-clf/brilliant_moves_clf/models/scaler_*.pkl
brilliant-moves-clf/brilliant_moves_clf/models/train_log_*.json

# Large binary networks (download separately, see README)
brilliant-moves-clf/brilliant_moves_clf/weights/*.pb.gz
brilliant-moves-clf/brilliant_moves_clf/weights/*.pb

# Scratch
*.log
*.tmp
raw_pgns/
moves_subset/

# LaTeX build outputs
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.pdf
!REPORT.pdf
